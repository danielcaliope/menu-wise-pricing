# Copie este arquivo para ".env" e preencha com os valores do seu projeto Supabase
# (Project Settings > API, no painel do Supabase ou do Lovable Cloud).
#
# Estes valores são públicos por design: a chave é a "anon/publishable key" do
# Supabase, protegida por Row Level Security (RLS) no banco, não por sigilo da
# chave. Ainda assim, o arquivo ".env" real não deve ser versionado — veja o
# achado sobre isso no relatório da Etapa 9.

VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"
